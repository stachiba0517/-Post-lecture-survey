VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# ダッシュボードの「anon」JWT または新形式の publishable（sb_publishable_...）のどちらでも可
VITE_SUPABASE_ANON_KEY=

# scripts/create-test-admin.mjs 実行時のみ（secret / service_role。コミット禁止）
# SUPABASE_SERVICE_ROLE_KEY=

# GitHub Pages の Project Pages（/リポジトリ名/）のときのみ設定（先頭・末尾スラッシュ付き推奨）
# 例: VITE_BASE_PATH=/gijutugassyuku/
